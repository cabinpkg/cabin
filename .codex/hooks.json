{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "d=\"$(git rev-parse --show-toplevel 2>/dev/null)\" && [ -f \"$d/scripts/ci.sh\" ] && exec bash \"$d/scripts/ci.sh\" --hook; echo '{}'",
            "timeout": 3600
          }
        ]
      }
    ]
  }
}
