{
    "name": "website",
    "version": "0.0.0",
    "private": true,
    "engines": {
        "node": ">=22.18"
    },
    "type": "module",
    "scripts": {
        "dev": "astro dev",
        "build": "yarn typecheck && astro build && yarn verify",
        "preview": "astro preview",
        "lint": "biome check .",
        "test": "node --test \"src/**/*.test.ts\" \"scripts/**/*.test.mjs\"",
        "typecheck": "astro check",
        "verify": "yarn verify:csp && yarn verify:docs-links && yarn verify:progressive",
        "verify:csp": "node scripts/verify-no-inline-scripts.mjs",
        "verify:docs-links": "node scripts/verify-docs-links.mjs",
        "verify:progressive": "node scripts/verify-progressive-independence.mjs",
        "fmt": "biome format . --write"
    },
    "dependencies": {
        "@fontsource-variable/cabin": "^5.3.0",
        "@fontsource/ibm-plex-mono": "^5.3.0",
        "@github/combobox-nav": "^3.0.2",
        "@lucide/astro": "^1.25.0",
        "fuse.js": "^7.5.0",
        "katex": "^0.18.0",
        "markdown-it": "^14.3.0",
        "rehype-katex": "^7.0.1",
        "remark-math": "^6.0.0",
        "semver": "^7.8.5",
        "smol-toml": "^1.7.0"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.0",
        "@astrojs/sitemap": "^3.7.3",
        "@biomejs/biome": "2.5.4",
        "@tailwindcss/typography": "^0.5.20",
        "@tailwindcss/vite": "^4.3.3",
        "@types/markdown-it": "^14.1.2",
        "@types/node": "26.1.1",
        "@types/semver": "^7.7.1",
        "astro": "^7.1.1",
        "parse5": "^8.0.1",
        "rehype-autolink-headings": "^7.1.0",
        "rehype-slug": "^6.0.0",
        "tailwindcss": "4.3.3",
        "typescript": "^6.0.3",
        "wrangler": "^4.112.0"
    },
    "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
