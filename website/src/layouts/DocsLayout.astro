---
import "katex/dist/katex.min.css";
import Icon from "../components/Icon.astro";
import DocsSidebar from "../components/docs/DocsSidebar.astro";
import { docEditUrl, docPath, getAdjacentDocs } from "../lib/docsNav";
import BaseLayout from "./BaseLayout.astro";

interface Heading {
    depth: number;
    slug: string;
    text: string;
}

interface Props {
    id: string;
    slug: string;
    title: string;
    headings: Heading[];
}

const { id, slug, title, headings } = Astro.props;

const toc = headings.filter(
    (heading) => heading.depth === 2 || heading.depth === 3,
);
const { prev, next } = getAdjacentDocs(slug);
const editUrl = docEditUrl(id);
---

<BaseLayout title={title} canonicalPath={docPath(slug)} searchMode="docs">
    <div
        class="mx-auto grid w-full max-w-screen-2xl gap-8 px-4 py-8 sm:px-6 lg:grid-cols-[15rem_minmax(0,1fr)] lg:py-10 xl:grid-cols-[15rem_minmax(0,1fr)_14rem]"
    >
        <div class="lg:sticky lg:top-[86px] lg:self-start">
            <details
                class="rounded-sm border border-line bg-night-raised lg:hidden"
            >
                <summary
                    class="cursor-pointer list-none px-4 py-3 text-sm font-bold text-ink"
                >
                    Documentation menu
                </summary>
                <nav aria-label="Documentation" class="px-2 pb-3">
                    <DocsSidebar slug={slug} />
                </nav>
            </details>
            <nav
                aria-label="Documentation"
                class="hidden px-1 lg:block lg:max-h-[calc(100vh-7rem)] lg:overflow-y-auto"
            >
                <DocsSidebar slug={slug} />
            </nav>
        </div>

        <article class="min-w-0">
            <div class="mb-6 flex justify-end">
                <a
                    href={editUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-sm text-ink-muted transition hover:text-steel-bright"
                >
                    <Icon name="external" class="h-4 w-4" />
                    Edit this page on GitHub
                </a>
            </div>

            <div
                class="prose prose-invert docs-prose max-w-none prose-headings:scroll-mt-24 prose-a:text-steel prose-a:no-underline hover:prose-a:underline prose-pre:rounded-md prose-pre:border prose-pre:border-line prose-img:rounded-md"
            >
                <slot />
            </div>

            {
                (prev || next) && (
                    <nav
                        aria-label="Documentation pages"
                        class="mt-12 flex flex-col gap-4 border-t border-line pt-6 sm:flex-row sm:justify-between"
                    >
                        {prev ? (
                            <a
                                href={docPath(prev.slug)}
                                class="group flex flex-col rounded-sm border border-line bg-night-raised px-4 py-3 transition-colors hover:border-steel/60 sm:max-w-[48%]"
                            >
                                <span class="font-mono text-xs text-ink-faint">Previous</span>
                                <span class="font-semibold text-ink group-hover:text-steel-bright">
                                    {prev.label}
                                </span>
                            </a>
                        ) : (
                            <span />
                        )}
                        {next && (
                            <a
                                href={docPath(next.slug)}
                                class="group flex flex-col rounded-sm border border-line bg-night-raised px-4 py-3 text-right transition-colors hover:border-steel/60 sm:ml-auto sm:max-w-[48%]"
                            >
                                <span class="font-mono text-xs text-ink-faint">Next</span>
                                <span class="font-semibold text-ink group-hover:text-steel-bright">
                                    {next.label}
                                </span>
                            </a>
                        )}
                    </nav>
                )
            }
        </article>

        {
            toc.length > 0 && (
                <aside
                    aria-label="On this page"
                    class="hidden xl:sticky xl:top-[86px] xl:block xl:self-start"
                >
                    <p class="pb-2 font-mono text-xs font-medium uppercase tracking-wider text-ink-faint">
                        On this page
                    </p>
                    <ul data-toc class="space-y-1 border-l border-line">
                        {toc.map((heading) => (
                            <li>
                                <a
                                    href={`#${heading.slug}`}
                                    data-toc-link={heading.slug}
                                    class:list={[
                                        "toc-link block border-l border-transparent py-1 text-sm text-ink-muted transition hover:border-steel hover:text-ink",
                                        heading.depth === 3 ? "pl-6" : "pl-3",
                                    ]}
                                >
                                    {heading.text}
                                </a>
                            </li>
                        ))}
                    </ul>
                </aside>
            )
        }
    </div>

    <span class="sr-only" aria-live="polite" data-copy-status></span>

    <script src="../scripts/docs.ts"></script>
</BaseLayout>
