---
import { getCollection } from "astro:content";
import GradientIcon from "../../components/GradientIcon.astro";
import Icon from "../../components/Icon.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildDocsSearchItems } from "../../lib/docsContent";
import {
    getDocsEmptySearchMessage,
    getDocsSearchCountLabel,
    getDocsSearchTitle,
} from "../../lib/docsSearch";

// Server-render the full docs list (a no-JS "browse all" fallback and first
// paint).  The client script reorders/filters these nodes in place from the
// fetched `/docs-search.json` index - no markup is rebuilt in JS.
const items = buildDocsSearchItems(await getCollection("docs"));
---

<BaseLayout
    title="Documentation"
    canonicalPath="/docs/search"
    contentClass="container-shell max-w-4xl py-10"
    searchMode="docs"
    typeahead={false}
>
    <section class="mb-8">
        <div class="flex items-start gap-4">
            <GradientIcon name="book" size="lg" />
            <div>
                <h1
                    id="docs-search-title"
                    class="text-3xl font-black tracking-tight md:text-4xl"
                >
                    {getDocsSearchTitle("")}
                </h1>
                <p id="docs-result-count" class="mt-2 text-slate-400">
                    {getDocsSearchCountLabel(items.length, items.length, "")}
                </p>
            </div>
        </div>
    </section>

    <section
        id="docs-empty-state"
        class:list={[
            "rounded-3xl border border-slate-800 bg-slate-950/60 px-6 py-16 text-center",
            items.length > 0 && "hidden",
        ]}
        aria-live="polite"
    >
        <div class="mb-6 flex justify-center text-slate-600">
            <Icon name="book" class="h-16 w-16" />
        </div>
        <h2 class="mb-3 text-2xl font-bold">No documentation found</h2>
        <p id="docs-empty-message" class="text-lg text-slate-500">
            {getDocsEmptySearchMessage("")}
        </p>
    </section>

    <ul id="docs-results" class="space-y-3" aria-live="polite">
        {
            items.map((item) => (
                <li data-doc-href={item.href}>
                    <a
                        href={item.href}
                        class="block rounded-2xl border border-slate-800 bg-slate-950/60 px-5 py-4 transition hover:border-sky-400/50"
                    >
                        <span class="block font-semibold text-slate-100">
                            {item.title}
                        </span>
                        {item.excerpt && (
                            <span class="mt-1 block text-sm text-slate-400">
                                {item.excerpt}
                            </span>
                        )}
                    </a>
                </li>
            ))
        }
    </ul>

    <script src="../../scripts/docs-search.ts"></script>
</BaseLayout>
