---
import Icon from "../components/Icon.astro";
import type { IconName } from "../components/Icon.astro";
import Button from "../components/ui/Button.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
    DOCS_URL,
    EXTERNAL_URLS,
    INSTALL_DOC_URL,
    SITE_DESCRIPTION,
} from "../lib/constants";
import { getLatestPackages } from "../lib/packages";

// The one build-time figure in the stats band: foundation ports are
// repo data, not registry data, so their count never needs a fetch.
const portCount = (await getLatestPackages()).length;

interface Feature {
    icon: IconName;
    title: string;
    description: string;
}

const features: Feature[] = [
    {
        icon: "bolt",
        title: "Deterministic builds",
        description:
            "Cabin plans the whole build as one Ninja graph: libraries, executables, tests, and examples. The same tree produces the same plan.",
    },
    {
        icon: "code",
        title: "Clear diagnostics",
        description:
            "When a manifest entry or a build step fails, Cabin says which one and why, in plain words.",
    },
    {
        icon: "box",
        title: "Foundation ports",
        description:
            "One line in cabin.toml pulls in zlib, libpng, SQLite, fmt, and other widely used C/C++ libraries. The recipes ship inside the cabin binary.",
    },
    {
        icon: "wrench",
        title: "C and C++",
        description:
            "C and C++ keep their own standards, compilers, and flags in the same project.",
    },
    {
        icon: "rocket",
        title: "Reproducible dependencies",
        description:
            "Lockfiles, vendoring, and offline builds pin each checkout to the same sources.",
    },
    {
        icon: "home",
        title: "GCC, Clang, and MSVC",
        description:
            "Cabin emits the right flag spelling for each compiler, so the same project builds under all three.",
    },
];

// Verified end to end against the cabin binary: `new` scaffolds a binary
// package whose main prints this exact greeting.
const quickstart = ["cabin new hello", "cd hello", "cabin run"];
const quickstartOutput = "Hello from Cabin";
---

<BaseLayout
    title="Cabin - Package manager and build system for C/C++"
    description={SITE_DESCRIPTION}
    canonicalPath="/"
>
    <section class="border-b border-line">
        <div
            class="container-shell grid grid-cols-1 items-center gap-12 py-16 md:py-24 lg:grid-cols-[minmax(0,5fr)_minmax(0,6fr)] lg:gap-16"
        >
            <div class="space-y-7">
                <div class="space-y-5">
                    <p class="spec-label">
                        # package management for C and C++
                    </p>
                    <h1
                        class="text-4xl font-bold leading-[1.08] tracking-tight md:text-5xl lg:text-[3.4rem]"
                    >
                        Build C/C++ packages with a Cargo-style workflow
                    </h1>
                    <p class="max-w-xl text-lg leading-8 text-ink-muted md:text-xl">
                        One cabin.toml describes the project. Cabin
                        resolves your compiler and dependencies, then plans
                        and runs the build.
                    </p>
                </div>

                <div class="flex flex-col gap-3 sm:flex-row">
                    <Button href={INSTALL_DOC_URL} variant="primary">
                        <Icon name="download" class="h-4 w-4" />
                        Install Cabin
                    </Button>
                    <Button href={DOCS_URL} variant="secondary">
                        Documentation
                        <Icon name="arrow-right" class="h-4 w-4" />
                    </Button>
                </div>
            </div>

            <figure
                class="overflow-hidden rounded-md border border-line bg-night-raised"
            >
                <figcaption
                    class="flex items-center justify-between border-b border-line px-4 py-2.5 font-mono text-xs"
                >
                    <span class="text-ink-muted">$ cabin</span>
                    <span class="text-ink-faint">demo</span>
                </figcaption>
                <img
                    src={EXTERNAL_URLS.demoGif}
                    width="800"
                    height="450"
                    alt="Demo of Cabin package manager"
                    loading="eager"
                    fetchpriority="high"
                    class="block h-auto w-full"
                />
            </figure>
        </div>
    </section>

    <section class="border-b border-line bg-night-raised">
        <div
            class="container-shell grid grid-cols-2 gap-x-10 gap-y-6 py-8 sm:grid-cols-4"
            data-registry-stats
        >
            <div>
                <p class="spec-label">Foundation ports</p>
                <p class="mt-2 font-mono text-2xl text-ink">{portCount}</p>
            </div>
            <div data-stat-tile hidden>
                <p class="spec-label">Registry packages</p>
                <p class="mt-2 font-mono text-2xl text-ink" data-stat-packages>
                </p>
            </div>
            <div data-stat-tile hidden>
                <p class="spec-label">Registry versions</p>
                <p class="mt-2 font-mono text-2xl text-ink" data-stat-versions>
                </p>
            </div>
            <div data-stat-tile hidden>
                <p class="spec-label">Downloads</p>
                <p class="mt-2 font-mono text-2xl text-ink" data-stat-downloads>
                </p>
            </div>
        </div>
    </section>

    <section class="py-16 md:py-24">
        <div class="container-shell">
            <div
                class="mb-12 flex flex-col gap-4 border-b border-line pb-8 md:flex-row md:items-end md:justify-between"
            >
                <div>
                    <p class="spec-label mb-3">[features]</p>
                    <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
                        What Cabin handles
                    </h2>
                </div>
                <p class="max-w-md leading-7 text-ink-muted md:text-right">
                    You write the manifest. Cabin finds the compiler,
                    fetches the libraries, and runs the build.
                </p>
            </div>

            <dl class="grid grid-cols-1 gap-x-10 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
                {
                    features.map((feature, index) => (
                        <div
                            class:list={[
                                // First-row cards (per the dl's 1/2/3-column
                                // breakpoints) skip the rule so it doesn't
                                // double the header's border-b.
                                index > 0 && "border-t border-line pt-5",
                                index === 1 && "sm:border-t-0 sm:pt-0",
                                index === 2 && "lg:border-t-0 lg:pt-0",
                            ]}
                        >
                            <dt class="flex items-center gap-3">
                                <Icon
                                    name={feature.icon}
                                    class="h-5 w-5 shrink-0 text-steel"
                                />
                                <span class="text-lg font-bold text-ink">
                                    {feature.title}
                                </span>
                            </dt>
                            <dd class="mt-3 ml-0 leading-7 text-ink-muted">
                                {feature.description}
                            </dd>
                        </div>
                    ))
                }
            </dl>
        </div>
    </section>

    <section class="border-t border-line bg-night-raised">
        <div
            class="container-shell grid grid-cols-1 items-center gap-12 py-16 md:py-24 lg:grid-cols-2 lg:gap-16"
        >
            <div>
                <p class="spec-label mb-3">[getting-started]</p>
                <h2 class="mb-4 text-3xl font-bold tracking-tight md:text-4xl">
                    Start with a package
                </h2>
                <p class="mb-8 max-w-xl text-lg leading-8 text-ink-muted">
                    cabin new gives you a package that builds and runs.
                    Dependencies are one line each in cabin.toml. The docs
                    cover the rest, from manifests to publishing.
                </p>
                <div class="flex flex-col gap-3 sm:flex-row">
                    <Button href={INSTALL_DOC_URL} variant="primary">
                        <Icon name="download" class="h-4 w-4" />
                        Read installation
                    </Button>
                    <Button href="/search" variant="secondary">
                        <Icon name="box" class="h-4 w-4" />
                        Browse Packages
                    </Button>
                </div>
            </div>

            <div class="overflow-hidden rounded-md border border-line bg-night">
                <p
                    class="flex items-center justify-between border-b border-line px-4 py-2.5 font-mono text-xs"
                >
                    <span class="text-ink-muted">quickstart</span>
                    <span class="text-ink-faint">sh</span>
                </p>
                <pre
                    class="overflow-x-auto px-4 py-4 font-mono text-sm leading-7 text-ink"><code>{
                    quickstart.map((line) => (
                        <span class="block"><span class="select-none text-ink-faint">$ </span>{line}</span>
                    ))
                }<span class="block text-ink-muted">{quickstartOutput}</span></code></pre>
            </div>
        </div>
    </section>
    <script src="../scripts/home-stats.ts"></script>
</BaseLayout>
