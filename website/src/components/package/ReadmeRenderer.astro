---
import { renderReadmeMarkdown } from "../../lib/markdown";
import Icon from "../Icon.astro";
import Card from "../ui/Card.astro";

interface Props {
    readme: string;
}

const { readme } = Astro.props;
const readmeHtml = renderReadmeMarkdown(readme);
---

<Card class="p-6">
    <div class="mb-4 flex items-center gap-2">
        <Icon name="book" class="h-5 w-5 text-steel" />
        <h2 class="text-xl font-bold">README</h2>
    </div>
    <div
        class="prose prose-invert max-w-none prose-a:text-steel prose-pre:border prose-pre:border-line"
        set:html={readmeHtml}
    />
</Card>
