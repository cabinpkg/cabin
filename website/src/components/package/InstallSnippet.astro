---
import type { PackageRecord } from "../../lib/packages";
import Icon from "../Icon.astro";
import Card from "../ui/Card.astro";
import CodeBlock from "../ui/CodeBlock.astro";

interface Props {
    package: PackageRecord;
}

const { package: pack } = Astro.props;
// Package names carry the synthetic "ports/" routing group; the cabin.toml
// dependency key is the bare port name, matching the bundled foundation port.
const portName = pack.name.replace(/^ports\//, "");
const installSnippet = `[dependencies]\n${portName} = { port = true, version = "=${pack.version}" }`;
---

<Card class="p-6">
    <div class="mb-4 flex items-center gap-2">
        <Icon name="download" class="h-5 w-5 text-pine" />
        <h2 class="text-xl font-bold">Installation</h2>
    </div>
    <p class="mb-3 leading-7 text-ink-muted">Add this to your <code class="rounded-sm bg-night-lifted px-1.5 py-0.5 font-mono text-sm text-ink">cabin.toml</code>:</p>
    <CodeBlock code={installSnippet} />
</Card>
