---
import { badgeToneClasses, joinClasses } from "../../lib/classes";

interface Props {
    tone?: keyof typeof badgeToneClasses;
    class?: string;
    [key: string]: unknown;
}

const { tone = "default", class: className = "", ...attrs } = Astro.props;
---

<span
    {...attrs}
    class={joinClasses(
        "inline-flex items-center justify-center gap-1.5 rounded-sm border px-2 py-1 font-mono text-xs font-medium",
        badgeToneClasses[tone],
        className,
    )}
>
    <slot />
</span>
