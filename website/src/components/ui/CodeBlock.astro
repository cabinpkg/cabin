---
interface Props {
    code: string;
    class?: string;
}

const { code, class: className = "" } = Astro.props;
---

<pre
    class:list={[
        "overflow-x-auto rounded-md border border-line bg-night-raised p-4 font-mono text-sm leading-7 text-ink",
        className,
    ]}
><code>{code}</code></pre>
