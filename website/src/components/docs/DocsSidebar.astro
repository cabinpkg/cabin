---
import { DOCS_HOME, DOCS_NAV, docPath } from "../../lib/docsNav";

interface Props {
    slug: string;
}

const { slug } = Astro.props;

const linkClass = (itemSlug: string) =>
    itemSlug === slug
        ? "block rounded-sm bg-steel/10 px-3 py-1.5 text-sm font-semibold text-steel-bright"
        : "block rounded-sm px-3 py-1.5 text-sm text-ink-muted transition-colors hover:bg-night-lifted hover:text-ink";
---

<a
    href={docPath(DOCS_HOME.slug)}
    class={linkClass(DOCS_HOME.slug)}
    aria-current={DOCS_HOME.slug === slug ? "page" : undefined}
>
    {DOCS_HOME.label}
</a>
{
    DOCS_NAV.map((section) => (
        <div class="mt-4">
            <p class="px-3 pb-1 font-mono text-xs font-medium uppercase tracking-wider text-ink-faint">
                {section.title}
            </p>
            <ul class="space-y-0.5">
                {section.items.map((item) => (
                    <li>
                        <a
                            href={docPath(item.slug)}
                            class={linkClass(item.slug)}
                            aria-current={item.slug === slug ? "page" : undefined}
                        >
                            {item.label}
                        </a>
                    </li>
                ))}
            </ul>
        </div>
    ))
}
