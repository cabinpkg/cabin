---
import BrandIcon from "./BrandIcon.astro";
import Icon from "./Icon.astro";
import { EXTERNAL_URLS, NAV_LINKS } from "../lib/constants";
import Button from "./ui/Button.astro";

const year = new Date().getFullYear();
---

<footer class="border-t border-line">
    <div class="container-shell py-16">
        <div class="flex flex-col items-center gap-8 text-center">
            <div class="flex flex-col items-center gap-4">
                <div class="flex items-center gap-1.5">
                    <img
                        src="/mark-steel.svg"
                        alt=""
                        width="44"
                        height="44"
                        class="h-10 w-10"
                    />
                    <h2
                        class="translate-y-[0.05em] text-2xl font-bold tracking-tight text-ink"
                    >
                        Cabin
                    </h2>
                </div>
                <p class="max-w-md leading-7 text-ink-muted">
                    C/C++ package manager and build system, inspired by
                    Cargo.
                </p>
            </div>

            <div class="flex flex-wrap justify-center gap-3 sm:hidden">
                <Button href={NAV_LINKS.docs.href} variant="ghost">
                    <Icon name="book" class="h-4 w-4" />
                    Documentation
                </Button>
                <Button
                    href={NAV_LINKS.github.href}
                    external
                    variant="ghost"
                >
                    <BrandIcon name="github" class="h-4 w-4 shrink-0" />
                    GitHub
                </Button>
            </div>

            <div class="h-px w-72 bg-line"></div>

            <div class="space-y-3">
                <p class="text-xs text-ink-faint">
                    © 2018-{year}
                    <a
                        href={EXTERNAL_URLS.author}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="font-semibold text-steel transition hover:text-steel-bright"
                    >
                        Ken Matsui</a>. All rights reserved.
                </p>
            </div>
        </div>
    </div>
</footer>
