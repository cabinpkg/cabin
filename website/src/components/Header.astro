---
import BrandIcon from "./BrandIcon.astro";
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";
import {
    ACCOUNT_URLS,
    DOCS_SEARCH_PATH,
    NAV_LINKS,
    SEARCH_PATH,
    SIGNIN_RESTRICTION,
} from "../lib/constants";
import Badge from "./ui/Badge.astro";
import Button from "./ui/Button.astro";

interface Props {
    // Which index the header search box queries.  Pages under /docs render with
    // `searchMode="docs"`; everything else searches packages.
    searchMode?: "packages" | "docs";
    // Results pages (/search, /docs/search) own the input through their own
    // script and pass `typeahead={false}` so the header typeahead stands down.
    typeahead?: boolean;
}

const { searchMode = "packages", typeahead = true } = Astro.props;

const isDocs = searchMode === "docs";
const searchAction = isDocs ? DOCS_SEARCH_PATH : SEARCH_PATH;
const searchPlaceholder = isDocs ? "Search docs..." : "Search packages...";
const searchLabel = isDocs ? "Search documentation" : "Search packages";
---

<header class="sticky top-0 z-50 border-b border-line bg-night">
    <nav
        class="mx-auto flex h-[70px] w-full max-w-screen-2xl items-center gap-4 px-4 sm:px-6"
        aria-label="Main navigation"
    >
        <a href="/" class="shrink-0" aria-label="Cabin home">
            <Logo />
        </a>

        <form
            action={searchAction}
            method="get"
            class="min-w-0 flex-1 sm:px-6"
            data-search-mode={searchMode}
            data-typeahead={typeahead ? "on" : "off"}
        >
            <label class="sr-only" for="site-search">{searchLabel}</label>
            <div class="relative">
                <div
                    class="flex h-10 items-center gap-2 rounded-sm border border-line bg-night-raised px-3.5 transition-colors focus-within:border-steel"
                >
                    <Icon
                        name="search"
                        class="h-4 w-4 shrink-0 text-ink-faint"
                    />
                    <input
                        id="site-search"
                        name="q"
                        type="search"
                        placeholder={searchPlaceholder}
                        class="w-full bg-transparent font-mono text-sm text-ink placeholder:text-ink-faint focus:outline-none"
                    />
                </div>
                <ul
                    id="site-search-suggestions"
                    role="listbox"
                    hidden
                    class="absolute inset-x-0 top-full z-40 mt-2 max-h-80 overflow-y-auto rounded-sm border border-line-strong bg-night-raised py-2 shadow-lg shadow-black/50"
                >
                </ul>
            </div>
        </form>

        <div class="hidden items-center gap-2 sm:flex">
            <Button href={NAV_LINKS.docs.href} variant="ghost">
                <Icon name="book" class="h-4 w-4" />
                {NAV_LINKS.docs.label}
            </Button>
            <Button
                href={NAV_LINKS.github.href}
                external
                variant="ghost"
                iconOnly
                ariaLabel={NAV_LINKS.github.label}
            >
                <BrandIcon name="github" class="h-5 w-5 shrink-0" />
            </Button>
        </div>

        {/* The static default is signed-out; account-nav.ts swaps in the
            signed-in link when the session probe says so, and leaves this
            untouched without JS or with the registry unreachable. */}
        <div class="flex shrink-0 items-center" data-account-nav>
            <span data-account-signed-out>
                {/* prefetch opt-out: /login is the Worker's stateful OAuth
                    route (mints the state cookie), never a static page. */}
                <Button
                    href={ACCOUNT_URLS.signIn}
                    variant="ghost"
                    title={SIGNIN_RESTRICTION}
                    data-astro-prefetch="false"
                >
                    Sign in
                    <Badge tone="muted">restricted</Badge>
                </Button>
            </span>
            {/* Signed-in: a disclosure button opening the account menu
                (account-nav.ts wires toggle, outside-click, and Escape). */}
            <span class="relative" data-account-signed-in hidden>
                <Button
                    type="button"
                    variant="ghost"
                    aria-expanded="false"
                    aria-controls="account-menu"
                    data-account-menu-button
                >
                    <Icon name="user" class="h-4 w-4" />
                    <span data-account-login></span>
                    <Icon name="chevron-down" class="h-3.5 w-3.5 text-ink-faint" />
                </Button>
                <div
                    id="account-menu"
                    class="absolute right-0 top-full z-40 mt-2 w-44 rounded-sm border border-line-strong bg-night-raised py-2 shadow-lg shadow-black/50"
                    hidden
                >
                    {
                        [
                            { label: "Dashboard", href: ACCOUNT_URLS.dashboard },
                            { label: "API tokens", href: ACCOUNT_URLS.tokens },
                            { label: "Profile", href: ACCOUNT_URLS.profile },
                        ].map((item) => (
                            <a
                                href={item.href}
                                class="block px-4 py-2 text-sm text-ink-muted transition-colors hover:bg-night-lifted hover:text-ink"
                            >
                                {item.label}
                            </a>
                        ))
                    }
                    <div class="mx-4 my-2 h-px bg-line"></div>
                    <button
                        type="button"
                        class="block w-full px-4 py-2 text-left text-sm text-ink-muted transition-colors hover:bg-night-lifted hover:text-ink"
                        data-account-signout
                    >
                        Sign out
                    </button>
                </div>
            </span>
        </div>
    </nav>
    <script src="../scripts/header-typeahead.ts"></script>
    <script src="../scripts/account-nav.ts"></script>
</header>
